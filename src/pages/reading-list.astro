<h2>Resilience & Performance</h2>
<div class="book-list">
  <div class="book-item">
    <div class="book-info">
      <h3>Can&#39;t Hurt Me: Master Your Mind and Defy the Odds</h3>
      <p class="book-author">David Goggins</p>
      <div class="book-tags">
        <span class="book-tag">Mindset</span>
        <span class="book-tag">Resilience</span>
        <span class="book-tag">Discipline</span>
      </div>
    </div>
  </div>
</div>

</Layout>

<style>
.page-intro {
  font-size: 1.125rem;
  color: var(--text-secondary);
  margin-bottom: var(--spacing-lg);
}

h2 {
  margin-top: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
}

h2:first-of-type {
  margin-top: 0;
}

.book-list {
  display: grid;
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-lg);
}

.book-item {
  padding: var(--spacing-md);
  padding-left: var(--spacing-md);
  border-left: 1px solid var(--border-color);
  background: transparent;
  transition: all 0.2s ease;
  position: relative;
}

.book-item:hover {
  border-left-color: var(--accent);
  padding-left: calc(var(--spacing-md) + 10px);
}

.book-item:last-child {
  border-left: 1px solid var(--border-color);
}

.book-item:last-child:hover {
  border-left-color: var(--accent);
}

.book-info {
  /* Reserve a tiny gutter for the hover chevron without shifting text alignment */
  padding-left: 16px;
}

.book-info h3 {
  font-size: 1.375rem;
  font-weight: 700;
  margin-bottom: 0.25rem;
  letter-spacing: -0.01em;
  color: var(--text-primary);
  position: relative;
}

.book-info h3::before {
  content: ">";
  position: absolute;
  left: -16px;
  top: 0;
  color: var(--accent);
  opacity: 0;
  transform: translateX(-10px);
  transition: all 0.2s ease;
}

.book-item:hover .book-info h3::before {
  opacity: 1;
  transform: translateX(0);
}

.book-item:hover .book-info h3 {
  color: var(--accent);
}

.book-author {
  font-family: var(--font-sans);
  font-size: 14px;
  color: var(--text-tertiary);
  margin-bottom: var(--spacing-xs);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.book-tags {
  display: flex;
  gap: var(--spacing-xs);
  flex-wrap: wrap;
}

.book-tag {
  font-family: var(--font-sans);
  font-size: 11px;
  padding: 0.25rem 0.5rem;
  background-color: transparent;
  color: var(--text-tertiary);
  border: 1px solid var(--border-color);
  text-transform: uppercase;
}

</style>
