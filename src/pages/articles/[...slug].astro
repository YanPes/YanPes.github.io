---
import { getCollection, type CollectionEntry } from 'astro:content';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteNav from '../../components/SiteNav.astro';
import { navLinks } from '../../data/siteContent';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout title={`${post.data.title} — Yannik Peschke`} description={post.data.description}>
  <SiteNav logo="Yannik Peschke" links={navLinks} />

  <main>
    <article class="section-shell article-page">
      <a href="/articles" class="back-link">← Back to articles</a>

      <header class="article-header">
        <p class="article-date">
          {post.data.date.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </p>
        <h1>{post.data.title}</h1>
        <p class="article-description">{post.data.description}</p>
      </header>

      <div class="article-content">
        <Content />
      </div>
    </article>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .article-page {
    padding-top: 7rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    text-decoration: none;
    color: var(--color-text-500);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .article-header {
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1.5rem;
  }

  .article-date {
    margin-bottom: 0.75rem;
    color: var(--color-text-600);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .article-header h1 {
    font-family: var(--font-mono);
    font-size: clamp(1.8rem, 5vw, 3rem);
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }

  .article-description {
    color: var(--color-text-500);
    max-width: 65ch;
  }

  .article-content {
    max-width: 72ch;
    color: var(--color-text-200);
  }

  .article-content :global(h2),
  .article-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-family: var(--font-mono);
  }

  .article-content :global(p),
  .article-content :global(li) {
    color: var(--color-text-500);
    line-height: 1.75;
  }

  .article-content :global(ul) {
    margin: 0.5rem 0 1rem 1.25rem;
  }

  .article-content :global(code) {
    background: var(--color-bg-800);
    border: 1px solid var(--color-border);
    padding: 0.1rem 0.3rem;
    border-radius: 4px;
    color: var(--color-accent);
  }
</style>
