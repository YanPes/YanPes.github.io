---
import { getCollection, type CollectionEntry } from 'astro:content';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteNav from '../../components/SiteNav.astro';
import { navLinks } from '../../data/siteContent';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
const articleOutline = headings.filter(({ depth }) => depth === 2 || depth === 3);
---

<BaseLayout title={`${post.data.title} — Yannik Peschke`} description={post.data.description}>
  <SiteNav logo="Yannik Peschke" links={navLinks} />

  <main>
    <article class="section-shell article-page">
      <a href="/articles" class="back-link">← Back to articles</a>

      <header class="article-header">
        <p class="article-date">
          {post.data.date.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </p>
        <h1>{post.data.title}</h1>
        <p class="article-description">{post.data.description}</p>
        {
          post.data.tags.length > 0 && (
            <ul class="article-tags" aria-label="Article tags">
              {post.data.tags.map((tag) => (
                <li class="article-tag">{tag}</li>
              ))}
            </ul>
          )
        }
      </header>

      <div class="article-layout">
        <div class="article-content">
          <Content />
        </div>
        {
          articleOutline.length > 0 && (
            <aside class="article-outline" aria-label="Article outline">
              <p class="article-outline-title">Overview</p>

              <ul class="article-outline-list">
                {articleOutline.map((heading) => (
                  <li class:list={['article-outline-item', heading.depth === 3 && 'is-subitem']}>
                    <a href={`#${heading.slug}`}>{heading.text}</a>
                  </li>
                ))}
              </ul>
            </aside>
          )
        }

      </div>
    </article>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .article-page {
    padding-top: 3rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--color-accent);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .back-link:hover {
    color: var(--color-accent-dim);
  }

  .article-header {
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1.5rem;
  }

  .article-date {
    margin-bottom: 0.75rem;
    color: var(--color-text-600);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .article-header h1 {
    font-family: var(--font-mono);
    font-size: clamp(1.8rem, 5vw, 3rem);
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }

  .article-description {
    color: var(--color-text-500);
    max-width: 65ch;
    font-size: 1.1rem;
    line-height: 1.7;
    letter-spacing: 0.002em;
  }

  .article-tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
    list-style: none;
  }

  .article-tag {
    border: 1px solid rgba(200, 241, 53, 0.2);
    background: rgba(200, 241, 53, 0.08);
    color: var(--color-accent);
    text-transform: uppercase;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    padding: 0.2rem 0.55rem;
  }

  .article-layout {
    display: grid;
    grid-template-columns: minmax(0, 70ch) minmax(220px, 1fr) ;
    align-items: start;
    gap: 2rem;
  }

  .article-outline {
    border: 1px solid var(--color-border);
    background: var(--color-bg-800);
    padding: 1rem;
    position: sticky;
    top: 7rem;
  }

  .article-outline-title {
    margin-bottom: 0.75rem;
    color: var(--color-text-600);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .article-outline-list {
    list-style: none;
  }

  .article-outline-item + .article-outline-item {
    margin-top: 0.4rem;
  }

  .article-outline-item a {
    color: var(--color-text-500);
    text-decoration: none;
    line-height: 1.45;
    transition: color var(--duration-fast) var(--ease-default);
  }

  .article-outline-item a:hover,
  .article-outline-item a:focus-visible {
    color: var(--color-accent);
  }



  .article-outline-item.is-subitem a {
    display: inline-block;
    padding-left: 0.9rem;
    color: var(--color-text-600);
    font-size: 0.95em;
  }

  .article-outline-item.is-subitem a:hover,
  .article-outline-item.is-subitem a:focus-visible {
    color: var(--color-accent-dim);
  }

  .article-content {
    color: var(--color-text-200);
    max-width: 70ch;
  }

  .article-content :global(h2),
  .article-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-family: var(--font-mono);
    scroll-margin-top: 5rem;
  }

  .article-content :global(h2) {
    position: relative;
    padding-left: 1.3rem;
    font-size: clamp(1.65rem, 1.2vw + 1.3rem, 1.85rem);
    line-height: 1.2;
    letter-spacing: 0.01em;
  }

  .article-content :global(h3) {
    font-size: clamp(1.3rem, 0.8vw + 1.05rem, 1.45rem);
    line-height: 1.3;
    letter-spacing: 0.008em;
  }

  .article-content :global(h2)::before {
    content: '_';
    position: absolute;
    top: 0px;
    left: 0;
    color: var(--color-accent);
    line-height: 1;
  }

  .article-content :global(p),
  .article-content :global(li) {
    color: var(--color-text-200);
    line-height: 1.78;
    letter-spacing: 0.002em;
    font-size: 1.15rem;
  }

  .article-content :global(p) {
    margin: 0 0 1rem;
  }

  .article-content :global(ul) {
    margin: 0.5rem 0 1rem 1.25rem;
  }

  .article-content :global(code) {
    background: var(--color-bg-800);
    border: 1px solid var(--color-border);
    padding: 0.1rem 0.3rem;
    border-radius: 4px;
    color: var(--color-accent);
    font-size: 0.9em;
  }

  .article-content :global(pre) {
    margin: 1.5rem 0;
    padding: 1rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg-800);
    overflow-x: auto;
    font-size: 0.9em;
    line-height: 1.65;
  }

  .article-content :global(pre code) {
    border: 0;
    background: transparent;
    padding: 0;
    font-size: inherit;
  }

  .article-content :global(img) {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 1.5rem 0;
  }

  .article-content :global(img):first-child() {
    margin-top: 0;
  }


  @media (max-width: 980px) {
    .article-layout {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }

    .article-outline {
      position: static;
    }
  }
</style>
