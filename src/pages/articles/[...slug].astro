---
import { getCollection, type CollectionEntry } from 'astro:content';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteNav from '../../components/SiteNav.astro';
import { navLinks } from '../../data/siteContent';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
const articleOutline = headings.filter(({ depth }) => depth === 2 || depth === 3);
---

<BaseLayout title={`${post.data.title} — Yannik Peschke`} description={post.data.description}>
  <SiteNav logo="Yannik Peschke" links={navLinks} />

  <main>
    <article class="section-shell article-page">
      <a href="/articles" class="back-link">← Back to articles</a>

      <header class="article-header">
        <p class="article-date">
          {post.data.date.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </p>
        <h1>{post.data.title}</h1>
        <p class="article-description">{post.data.description}</p>
      </header>

      <div class="article-layout">
        <div class="article-content">
          <Content />
        </div>
        {
          articleOutline.length > 0 && (
            <aside class="article-outline" aria-label="Article outline">
              <p class="article-outline-title">Overview</p>

              <ul class="article-outline-list">
                {articleOutline.map((heading) => (
                  <li class:list={['article-outline-item', heading.depth === 3 && 'is-subitem']}>
                    <a href={`#${heading.slug}`}>{heading.text}</a>
                  </li>
                ))}
              </ul>
            </aside>
          )
        }

      </div>
    </article>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .article-page {
    padding-top: 7rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--color-accent);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .back-link:hover {
    color: var(--color-accent-dim);
  }

  .article-header {
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1.5rem;
  }

  .article-date {
    margin-bottom: 0.75rem;
    color: var(--color-text-600);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .article-header h1 {
    font-family: var(--font-mono);
    font-size: clamp(1.8rem, 5vw, 3rem);
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }

  .article-description {
    color: var(--color-text-500);
    max-width: 65ch;
  }

  .article-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(220px, 280px) ;
    align-items: start;
    gap: 2rem;
  }

  .article-outline {
    border: 1px solid var(--color-border);
    background: var(--color-bg-800);
    padding: 1rem;
    position: sticky;
    top: 7rem;
  }

  .article-outline-title {
    margin-bottom: 0.75rem;
    color: var(--color-text-600);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .article-outline-list {
    list-style: none;
  }

  .article-outline-item + .article-outline-item {
    margin-top: 0.4rem;
  }

  .article-outline-item a {
    color: var(--color-text-500);
    text-decoration: none;
    line-height: 1.45;
    transition: color var(--duration-fast) var(--ease-default);
  }

  .article-outline-item a:hover,
  .article-outline-item a:focus-visible {
    color: var(--color-accent);
  }

  .article-outline-item.is-subitem a {
    display: inline-block;
    padding-left: 0.9rem;
    color: var(--color-text-600);
    font-size: 0.95em;
  }

  .article-content {
    color: var(--color-text-200);
  }

  .article-content :global(h2),
  .article-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-family: var(--font-mono);
    scroll-margin-top: 5rem;
  }

  .article-content :global(p),
  .article-content :global(li) {
    color: var(--color-text-500);
    line-height: 1.75;
  }

  .article-content :global(ul) {
    margin: 0.5rem 0 1rem 1.25rem;
  }

  .article-content :global(code) {
    background: var(--color-bg-800);
    border: 1px solid var(--color-border);
    padding: 0.1rem 0.3rem;
    border-radius: 4px;
    color: var(--color-accent);
  }

  @media (max-width: 980px) {
    .article-layout {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }

    .article-outline {
      position: static;
    }
  }
</style>
