---
import Layout from '../layouts/Layout.astro';
import Article from '../components/Article.astro';
---

<Layout 
  title="Blog — Yannik Peschke" 
  description="Articles about software architecture, microfrontends, and system design by Yannik Peschke."
>

<h1>Writing</h1>
<p class="page-intro">
    I always try new challenges - Starting to write about technical topics is a new way for me to express myself, my thoughts and give something back to the engineering community.
  </p>

<div class="filter-tags">
  <button class="tag active" data-filter="all">All Articles</button>
  <button class="tag" data-filter="architecture">Architecture</button>
  <button class="tag" data-filter="microfrontends">Microfrontends</button>
  <button class="tag" data-filter="system-design">System Design</button>
</div>

<div class="articles-list">
  <Article
    title="Your Guide to Architectural Decisions in Enterprise Development with Module Federation"
    date="January 29, 2025"
    readTime="7 min read"
    tags={['Microfrontends', 'Architecture']}
  />
</div>

</Layout>

<style>
.page-intro {
  font-size: 1.125rem;
  color: var(--text-secondary);
  margin-bottom: var(--spacing-xl);
}

.filter-tags {
  display: flex;
  gap: var(--spacing-sm);
  flex-wrap: wrap;
  margin-bottom: var(--spacing-lg);
  font-family: var(--font-main);
}

.tag {
  padding: 0.5rem 1rem;
  font-size: 12px;
  background-color: transparent;
  border: 1px dashed var(--border-color);
  color: var(--text-secondary);
  cursor: pointer;
  transition: all 0.2s ease;
  font-family: var(--font-main);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-weight: 700;
}

.tag:hover, .tag.active {
  background-color: transparent;
  color: var(--accent);
  border-color: var(--accent);
  border-style: solid;
  text-shadow: 0 0 5px rgba(192, 254, 4, 0.4);
}

.tag.active::before {
  content: "[x] ";
}

.tag:not(.active)::before {
  content: "[ ] ";
}

.articles-list {
  display: grid;
  gap: var(--spacing-md);
}

@media (max-width: 768px) {
  h1 {
    margin-bottom: var(--spacing-sm);
  }
}
</style>

<script>
  // Filter functionality
  const filterTags = document.querySelectorAll('.tag');
  const articles = document.querySelectorAll('.article-card');

  filterTags.forEach(tag => {
    tag.addEventListener('click', () => {
      const filter = tag.getAttribute('data-filter');
      
      filterTags.forEach(t => t.classList.remove('active'));
      tag.classList.add('active');

      articles.forEach(article => {
        const tags = article.getAttribute('data-tags');
        
        if (filter === 'all' || tags.includes(filter)) {
          article.style.display = 'block';
        } else {
          article.style.display = 'none';
        }
      });
    });
  });
</script>
