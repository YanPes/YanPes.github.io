---
import { getCollection } from 'astro:content';
import ArticlesSection from '../components/ArticlesSection.astro';
import HeroSection from '../components/HeroSection.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteNav from '../components/SiteNav.astro';
import StackSection from '../components/StackSection.astro';
import StatsBar from '../components/StatsBar.astro';
import TerminalSection from '../components/TerminalSection.astro';
import { type ArticleItem, heroContent, navLinks, stackItems, stats } from '../data/siteContent';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const compactDate = (date: Date) =>
  date.toLocaleDateString('en-US', {
    month: 'short',
    year: 'numeric',
  });

const toArticleCard = (
  post: (typeof posts)[number],
  featuredNumber?: string,
): ArticleItem => ({
  title: post.data.title,
  excerpt: post.data.description,
  date: compactDate(post.data.date),
  readTime: post.data.readTime,
  tag: post.data.tags[0] ?? 'Article',
  href: `/articles/${post.slug}`,
  featuredNumber,
});

const featuredArticle = posts[0] ? toArticleCard(posts[0], '01') : null;
const recentArticles = posts.slice(1, 3).map((post) => toArticleCard(post));
---

<BaseLayout>
  <SiteNav logo="Yannik Peschke" links={navLinks} />

  <main>
    <HeroSection {...heroContent} />
    <StatsBar items={stats} />
    <ArticlesSection featured={featuredArticle} items={recentArticles} />
    <TerminalSection />
    <StackSection items={stackItems} />
  </main>

  <SiteFooter />
</BaseLayout>
