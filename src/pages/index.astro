---
import ArticlesSection from '../components/ArticlesSection.astro';
import HeroSection from '../components/HeroSection.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteNav from '../components/SiteNav.astro';
import StackSection from '../components/StackSection.astro';
import StatsBar from '../components/StatsBar.astro';
import TerminalSection from '../components/TerminalSection.astro';
import {
  featuredArticle,
  heroContent,
  navLinks,
  recentArticles,
  stackItems,
  stats,
} from '../data/siteContent';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <SiteNav logo="Yannik Peschke" links={navLinks} />

  <main>
    <HeroSection {...heroContent} />
    <StatsBar items={stats} />
    <ArticlesSection featured={featuredArticle} items={recentArticles} />
    <TerminalSection />
    <StackSection items={stackItems} />
  </main>

  <SiteFooter />
</BaseLayout>
