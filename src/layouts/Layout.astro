---
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Yannik Peschke — Frontend Architect | Advocate for Module Federation & Rspack Ecosystem | Micro Frontends & Tooling",
	description = "Personal website of Yannik Peschke. Writing about software architecture, microfrontends, and system design.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@100..800&display=swap" rel="stylesheet">
	</head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
	</body>
</html>

<style>
:root {
  --bg-primary: #000000;
  --bg-secondary: #111111;
  --text-primary: #ffffff;
  --text-secondary: #cccccc;
  --text-tertiary: #888888;
  --border-color: #333333;
  --accent: rgb(192, 254, 4);
  --accent-secondary: #ffffff;
  --accent-hover: rgba(192, 254, 4, 0.8);

  --font-main: "JetBrains Mono", monospace;

  --container-max: 720px;
  --spacing-xs: 0.5rem;
  --spacing-sm: 1rem;
  --spacing-md: 2rem;
  --spacing-lg: 3rem;
  --spacing-xl: 4rem;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: var(--font-main);
  font-size: 16px;
  line-height: 1.6;
  color: var(--text-primary);
  background-color: var(--bg-primary);
  transition: background-color 0.3s ease, color 0.3s ease;
}

main {
  max-width: var(--container-max);
  margin: 0 auto;
  padding: var(--spacing-xl) var(--spacing-sm);
  min-height: calc(100vh - 200px);
}

section {
  margin-bottom: var(--spacing-xl);
}

:global(h1) {
  font-size: clamp(2.0rem, 5vw, 2.5rem);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -0.05em;
  text-transform: uppercase;
  margin-bottom: var(--spacing-md);
}

:global(h2::before) {
    content: "_";
    margin-right: 4px;
    color: var(--accent);
}

h2, h3, h4, h5, h6 {
  color: var(--text-primary);
  font-weight: 600;
  margin-bottom: var(--spacing-sm);
  letter-spacing: -0.02em;
}

a {
  color: var(--text-primary);
  text-decoration: none;
  border-bottom: 1px solid var(--accent);
  transition: all 0.2s ease;
}

a:hover {
  background-color: var(--accent);
  color: var(--bg-primary);
}

code {
  font-family: var(--font-main);
  background: var(--bg-secondary);
  padding: 0.2em 0.4em;
  border-radius: 4px;
  font-size: 0.9em;
  color: var(--accent);
}

pre {
  padding: var(--spacing-md);
  background: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: 8px;
  overflow-x: auto;
  margin: var(--spacing-md) 0;
}

blockquote {
  border-left: 4px solid var(--accent);
  padding-left: var(--spacing-md);
  margin: var(--spacing-md) 0;
  font-style: italic;
  color: var(--text-secondary);
}

::selection {
  background: var(--accent);
  color: var(--bg-primary);
}

@media (max-width: 768px) {
  :root {
    --spacing-lg: 2rem;
    --spacing-xl: 3rem;
  }

  main {
    padding: var(--spacing-lg) var(--spacing-sm);
  }
}
</style>
