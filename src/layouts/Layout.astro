---
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Yannik Peschke — Frontend Architect | Advocate for Module Federation & Rspack Ecosystem | Micro Frontends & Tooling",
	description = "Personal website of Yannik Peschke. Writing about software architecture, microfrontends, and system design.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;500;600;700&display=swap" rel="stylesheet">
	</head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
	</body>
</html>

<style>
:root {
  --bg-primary: #ffffff;
  --bg-secondary: #fafafa;
  --text-primary: #1a1a1a;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --border-color: #e5e5e5;
  --accent: #1a1a1a;
  --accent-hover: #333333;

  --font-serif: Georgia, "Times New Roman", Times, serif;
  --font-sans: "Lato", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, "Open Sans", "Helvetica Neue", sans-serif;

  --container-max: 720px;
  --spacing-xs: 0.5rem;
  --spacing-sm: 1rem;
  --spacing-md: 2rem;
  --spacing-lg: 3rem;
  --spacing-xl: 4rem;
}

[data-theme="dark"] {
  --bg-primary: #0a0a0a;
  --bg-secondary: #121212;
  --text-primary: #e5e5e5;
  --text-secondary: #a0a0a0;
  --text-tertiary: #666666;
  --border-color: #2a2a2a;
  --accent: #e5e5e5;
  --accent-hover: #ffffff;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: var(--font-serif);
  font-size: 18px;
  line-height: 1.7;
  color: var(--text-primary);
  background-color: var(--bg-primary);
  transition: background-color 0.3s ease, color 0.3s ease;
}

main {
  max-width: var(--container-max);
  margin: 0 auto;
  padding: var(--spacing-xl) var(--spacing-sm);
  min-height: calc(100vh - 200px);
}

section {
  margin-bottom: var(--spacing-xl);
}

h1 {
  font-size: clamp(2.5rem, 5vw, 3.5rem);
  font-weight: 300;
  line-height: 1.1;
  margin-bottom: var(--spacing-sm);
  letter-spacing: -0.03em;
}

h2 {
  font-size: clamp(1.75rem, 3vw, 2.25rem);
  font-weight: 400;
  margin-bottom: var(--spacing-md);
  letter-spacing: -0.02em;
}

h3 {
  font-size: 1.5rem;
  font-weight: 600;
  margin-bottom: var(--spacing-xs);
  letter-spacing: -0.01em;
}

p {
  margin-bottom: var(--spacing-md);
  font-size: 1.125rem;
}

@media (max-width: 768px) {
  :root {
    --spacing-lg: 2rem;
    --spacing-xl: 3rem;
  }

  main {
    padding: var(--spacing-lg) var(--spacing-sm);
  }
}
</style>

<script>
  // Theme toggle functionality
  const themeToggle = document.querySelector('.theme-toggle');
  const themeIcon = document.querySelector('.theme-icon');
  const html = document.documentElement;

  // Check for saved theme preference or default to light
  const currentTheme = localStorage.getItem('theme') || 'light';
  html.setAttribute('data-theme', currentTheme);
  if (themeIcon) {
    themeIcon.textContent = currentTheme === 'dark' ? '☀' : '☾';
  }

  if (themeToggle) {
    themeToggle.addEventListener('click', () => {
      const currentTheme = html.getAttribute('data-theme');
      const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
      
      html.setAttribute('data-theme', newTheme);
      localStorage.setItem('theme', newTheme);
      if (themeIcon) {
        themeIcon.textContent = newTheme === 'dark' ? '☀' : '☾';
      }
    });
  }
</script>
