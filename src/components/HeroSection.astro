---
import type { ContactLink } from '../data/siteContent';

interface Props {
  statuses: string[];
  title: string;
  accentName: string;
  role: string;
  description: string;
  ctaLabel: string;
  ctaHref: string;
  contactLinks: ContactLink[];
}

const {
  statuses,
  title,
  accentName,
  role,
  ctaLabel,
  ctaHref,
  contactLinks,
} = Astro.props;
---

<section id="home" class="hero section-shell">
  <div class="hero-container">
    <div class="hero-status-list">
      {statuses.map((status) => <div class="hero-status">{status}</div>)}
    </div>

    <h1 class="hero-title">
      {title}<br />
      <span class="accent">{accentName}</span>
    </h1>

    <p class="hero-role">{role}</p>

    <div class="hero-actions">
      <div class="hero-contact-links" aria-label="Contact links">
        {
        contactLinks.map((link) => (
        <a href={link.href} class="hero-contact-link" target="_blank" rel="noopener noreferrer" aria-label={link.label}>
          <img src={link.iconSrc} alt="" loading="lazy" decoding="async" />
        </a>
        ))
        }
      </div>
      <a href={ctaHref} class="hero-cta">{ctaLabel}</a>

    </div>
  </div>
</section>
