---
import type { ArticleItem } from '../data/siteContent';
import ArticleCard from './ArticleCard.astro';
import SectionHeader from './SectionHeader.astro';

interface Props {
  featured: ArticleItem;
  items: ArticleItem[];
}

const { featured, items } = Astro.props;
---

<section id="articles" class="section-shell">
  <SectionHeader title="Recent Articles" linkLabel="All articles →" linkHref="#" />

  <div class="articles-grid">
    <ArticleCard article={featured} featured />
    {items.map((article) => <ArticleCard article={article} />)}
  </div>
</section>
