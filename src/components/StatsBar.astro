---
import type { StatItem } from '../data/siteContent';

interface Props {
  items: StatItem[];
}

const { items } = Astro.props;
---

<section class="stats-bar" aria-label="Highlights">
  {
    items.map((stat) => (
      <article class="stat">
        <p class="stat-num">{stat.value}</p>
        <p class="stat-label">{stat.label}</p>
      </article>
    ))
  }
</section>
