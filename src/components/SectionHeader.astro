---
interface Props {
  title: string;
  linkLabel?: string;
  linkHref?: string;
}

const { title, linkLabel, linkHref = '#' } = Astro.props;
---

<div class="section-header">
  <h2 class="section-title">{title}</h2>
  {linkLabel && (
    <a href={linkHref} class="section-link">
      {linkLabel}
    </a>
  )}
</div>
