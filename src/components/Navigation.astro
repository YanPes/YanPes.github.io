---
const currentPath = Astro.url.pathname;
const isActive = (path: string) => {
  if (path === '/' && currentPath === '/') return true;
  if (path !== '/' && currentPath.startsWith(path)) return true;
  return false;
};
---

<nav>
  <a href="/" class="logo">Yannik Peschke</a>
  <ul class="nav-links">
    <li><a href="/" class={isActive('/') ? 'active' : ''}>Home</a></li>
    <li><a href="/about" class={isActive('/about') ? 'active' : ''}>About</a></li>
    <li><a href="/blog" class={isActive('/blog') ? 'active' : ''}>Blog</a></li>
    <li><a href="/reading-list" class={isActive('/reading-list') ? 'active' : ''}>Reading List</a></li>
    <li><a href="/what-i-use" class={isActive('/what-i-use') ? 'active' : ''}>What I Use</a></li>
  </ul>
</nav>

<style>
nav {
  max-width: var(--container-max);
  margin: 0 auto;
  padding: var(--spacing-md) var(--spacing-sm);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}

.logo {
  font-family: var(--font-main);
  font-size: 16px;
  font-weight: 700;
  text-decoration: none;
  color: var(--accent);
  letter-spacing: -0.05em;
  text-transform: uppercase;
  border-bottom: none;
  position: relative;
}

.logo::after {
  content: "";
  display: inline-block;
  width: 10px;
  height: 18px;
  background-color: var(--accent);
  margin-left: 5px;
  margin-bottom: 2px;
  vertical-align: middle;
  animation: blink 1s step-end infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

.logo:hover {
  background: none;
  text-shadow: 0 0 10px var(--accent);
}

.nav-links {
  display: flex;
  gap: var(--spacing-md);
  list-style: none;
  font-family: var(--font-main);
  font-size: 14px;
  flex-wrap: wrap;
  text-transform: uppercase;
}

.nav-links a {
  color: var(--text-secondary);
  text-decoration: none;
  transition: all 0.2s ease;
  border-bottom: 1px solid transparent;
}

.nav-links a:hover,
.nav-links a.active {
  color: var(--accent);
  border-bottom: 1px solid var(--accent);
  text-shadow: 0 0 8px rgba(192, 254, 4, 0.4);
}

.nav-links a:hover {
  background: none;
}

@media (max-width: 768px) {
  nav {
    padding: var(--spacing-sm);
  }

  .nav-links {
    gap: var(--spacing-sm);
    font-size: 12px;
  }
}
</style>

<script>
  // Client-side active state update for better UX
  const currentPath = window.location.pathname;
  const navLinks = document.querySelectorAll('.nav-links a');
  
  navLinks.forEach(link => {
    const href = link.getAttribute('href');
    if (href === '/' && currentPath === '/') {
      link.classList.add('active');
    } else if (href !== '/' && currentPath.startsWith(href)) {
      link.classList.add('active');
    } else {
      link.classList.remove('active');
    }
  });
</script>
