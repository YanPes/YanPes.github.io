---
import type { StackItem } from '../data/siteContent';
import SectionHeader from './SectionHeader.astro';

interface Props {
  items: StackItem[];
}

const { items } = Astro.props;
---

<section id="stack" class="section-shell">
  <SectionHeader title="Current Stack" linkLabel="Full list →" linkHref="#" />

  <div class="stack-grid" role="list" aria-label="Technology stack">
    {
      items.map((item) => (
        <span class:list={['stack-tag', { highlight: item.highlight }]} role="listitem">
          {item.label}
        </span>
      ))
    }
  </div>
</section>
